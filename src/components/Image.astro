---
import type { ImageMetadata } from 'astro';

const { src, alt, class: className = '' } = Astro.props;
const img = src as ImageMetadata;
const isObj = img && typeof img === 'object' && img.src;
---

<img
  src={isObj ? img.src : src}
  alt={alt}
  class={className}
  width={isObj ? img.width : undefined}
  height={isObj ? img.height : undefined}
  loading="lazy"
  decoding="async"
/>
